DATABASE_URL="postgresql://username:password@hostname/database?sslmode=require"
NEXT_PUBLIC_AUTHENTICATION_CLERK_PUBLISHABLE_KEY="pk_test_your_publishable_key"
CLERK_SECRET_KEY="sk_test_your_secret_key"
# The landing page at / is the employee sign-in screen.
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/"
# Self-sign-up is disabled in the UI by default, but you can keep a route reserved.
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
